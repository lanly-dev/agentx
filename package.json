{
  "name": "agentx",
  "displayName": "AI Agent Free Tier Quota Tracker",
  "description": "Track and monitor free tier quota usage across AI providers including OpenAI, Anthropic, Google Gemini, and more",
  "version": "0.1.0",
  "publisher": "agentx",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "icon": "icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agentx-quota-sidebar",
          "title": "AI Quota Tracker",
          "icon": "icon.svg"
        }
      ]
    },
    "views": {
      "agentx-quota-sidebar": [
        {
          "type": "tree",
          "id": "agentxQuotaSidebar",
          "name": "AI Quotas"
        }
      ]
    },
    "commands": [
      {
        "command": "agentx.showQuotaPanel",
        "title": "agentx: Show Quota Sidebar"
      },
      {
        "command": "agentx.recordUsage",
        "title": "agentx: Record Usage"
      },
      {
        "command": "agentx.quickRecordUsage",
        "title": "agentx: Quick Record Usage"
      },
      {
        "command": "agentx.editLimits",
        "title": "agentx: Edit Provider Limits"
      },
      {
        "command": "agentx.listProviders",
        "title": "agentx: List & Toggle Providers"
      },
      {
        "command": "agentx.showAlerts",
        "title": "agentx: Show Alerts"
      },
      {
        "command": "agentx.resetAllQuota",
        "title": "agentx: Reset All Quotas"
      },
      {
        "command": "agentx.resetProvider",
        "title": "agentx: Reset Provider Quota"
      },
      {
        "command": "agentx.addCustomProvider",
        "title": "agentx: Add Custom Provider"
      },
      {
        "command": "agentx.exportQuota",
        "title": "agentx: Export Quota Data"
      },
      {
        "command": "agentx.importQuota",
        "title": "agentx: Import Quota Data"
      },
      {
        "command": "agentx.refreshQuota",
        "title": "agentx: Refresh View"
      },
      {
        "command": "agentx.toggleAutoTrack",
        "title": "agentx: Toggle Auto-Tracking"
      },
      {
        "command": "agentx.recordApiUsage",
        "title": "agentx: Record API Usage (internal)"
      },
      {
        "command": "agentx.sidebarToggleProvider",
        "title": "Toggle Provider"
      },
      {
        "command": "agentx.sidebarResetProvider",
        "title": "Reset Provider Quota"
      },
      {
        "command": "agentx.sidebarRecordUsage",
        "title": "Record +1 Request"
      },
      {
        "command": "agentx.sidebarEditLimits",
        "title": "Edit Limits..."
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "agentx.showQuotaPanel",
          "when": "true"
        },
        {
          "command": "agentx.recordUsage",
          "when": "true"
        },
        {
          "command": "agentx.quickRecordUsage",
          "when": "true"
        },
        {
          "command": "agentx.editLimits",
          "when": "true"
        },
        {
          "command": "agentx.listProviders",
          "when": "true"
        },
        {
          "command": "agentx.showAlerts",
          "when": "true"
        },
        {
          "command": "agentx.resetAllQuota",
          "when": "true"
        },
        {
          "command": "agentx.addCustomProvider",
          "when": "true"
        },
        {
          "command": "agentx.exportQuota",
          "when": "true"
        },
        {
          "command": "agentx.importQuota",
          "when": "true"
        },
        {
          "command": "agentx.toggleAutoTrack",
          "when": "true"
        }
      ],
      "view/item/context": [
        {
          "command": "agentx.sidebarRecordUsage",
          "when": "view == agentxQuotaSidebar && viewItem == provider-enabled",
          "group": "inline"
        },
        {
          "command": "agentx.sidebarToggleProvider",
          "when": "view == agentxQuotaSidebar && viewItem == provider-enabled",
          "group": "inline"
        },
        {
          "command": "agentx.sidebarToggleProvider",
          "when": "view == agentxQuotaSidebar && viewItem == provider-disabled",
          "group": "inline"
        },
        {
          "command": "agentx.sidebarResetProvider",
          "when": "view == agentxQuotaSidebar && viewItem == provider-enabled"
        },
        {
          "command": "agentx.sidebarEditLimits",
          "when": "view == agentxQuotaSidebar && viewItem == provider-enabled"
        }
      ],
      "view/title": [
        {
          "command": "agentx.refreshQuota",
          "when": "view == agentxQuotaSidebar",
          "group": "navigation"
        },
        {
          "command": "agentx.resetAllQuota",
          "when": "view == agentxQuotaSidebar"
        },
        {
          "command": "agentx.toggleAutoTrack",
          "when": "view == agentxQuotaSidebar"
        }
      ]
    },
    "configuration": {
      "title": "AI Agent Free Tier Quota Tracker",
      "properties": {
        "agentx.quotaTracker.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the quota tracker"
        },
        "agentx.quotaTracker.autoTrack": {
          "type": "boolean",
          "default": true,
          "description": "Automatically detect and track AI API calls by intercepting HTTP requests"
        },
        "agentx.quotaTracker.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show quota usage in the status bar"
        },
        "agentx.quotaTracker.showAlerts": {
          "type": "boolean",
          "default": true,
          "description": "Show warning notifications when approaching quota limits"
        },
        "agentx.quotaTracker.alertThreshold": {
          "type": "number",
          "default": 80,
          "minimum": 10,
          "maximum": 100,
          "description": "Percentage threshold at which to start showing quota warnings"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "efix": "eslint . --fix",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/vscode": "^1.125.0",
    "eslint": "^9.39.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  }
}